#include <stdio.h>
#include <stdlib.h>

/* Structure to store value and original index */
typedef struct {
    int value;
    int index;
} Pair;

/* Merge function */
void merge(Pair arr[], int left, int mid, int right, int count[]) {
    int n1 = mid - left + 1;
    int n2 = right - mid;

    Pair *L = (Pair *)malloc(n1 * sizeof(Pair));
    Pair *R = (Pair *)malloc(n2 * sizeof(Pair));

    for (int i = 0; i < n1; i++)
        L[i] = arr[left + i];
    for (int j = 0; j < n2; j++)
        R[j] = arr[mid + 1 + j];

    int i = 0, j = 0, k = left;
    int rightSmallerCount = 0;

    while (i < n1 && j < n2) {
        if (L[i].value <= R[j].value) {
            count[L[i].index] += rightSmallerCount;
            arr[k++] = L[i++];
        } else {
            rightSmallerCount++;
            arr[k++] = R[j++];
        }
    }

    while (i < n1) {
        count[L[i].index] += rightSmallerCount;
        arr[k++] = L[i++];
    }

    while (j < n2) {
        arr[k++] = R[j++];
    }

    free(L);
    free(R);
}

/* Merge Sort */
void mergeSort(Pair arr[], int left, int right, int count[]) {
    if (left < right) {
        int mid = left + (right - left) / 2;
        mergeSort(arr, left, mid, count);
        mergeSort(arr, mid + 1, right, count);
        merge(arr, left, mid, right, count);
    }
}

/* Driver function */
int main() {
    int nums[] = {5, 2, 6, 1};
    int n = sizeof(nums) / sizeof(nums[0]);

    Pair *arr = (Pair *)malloc(n * sizeof(Pair));
    int *count = (int *)calloc(n, sizeof(int));

    for (int i = 0; i < n; i++) {
        arr[i].value = nums[i];
        arr[i].index = i;
    }

    mergeSort(arr, 0, n - 1, count);

    printf("Count of smaller elements to the right:\n");
    for (int i = 0; i < n; i++) {
        printf("%d ", count[i]);
    }
    printf("\n");

    free(arr);
    free(count);
    return 0;
}
