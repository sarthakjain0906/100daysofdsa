def counting_sort(arr):
    if not arr:
        return arr

    # Find maximum value
    max_val = max(arr)

    # Build frequency array
    count = [0] * (max_val + 1)
    for x in arr:
        count[x] += 1

    # Compute prefix sums
    for i in range(1, len(count)):
        count[i] += count[i - 1]

    # Build output array (stable)
    output = [0] * len(arr)
    for i in range(len(arr) - 1, -1, -1):
        x = arr[i]
        count[x] -= 1
        output[count[x]] = x

    return output
